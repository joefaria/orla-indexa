---
interface Props {
  step: number;
  title: string;
  description: string;
  isLast?: boolean;
}

const { step, title, description, isLast = false } = Astro.props;
---

<div class="relative flex flex-col items-center text-center md:flex-1">
  <!-- Step number -->
  <div class="relative z-10 mb-4 flex h-14 w-14 items-center justify-center rounded-xl border border-accent/30 bg-accent-subtle">
    <span class="font-mono text-sm font-semibold text-accent-light">
      {String(step).padStart(2, '0')}
    </span>
  </div>

  <!-- Connector line (desktop) -->
  {!isLast && (
    <div class="absolute top-7 left-[calc(50%+28px)] hidden h-px w-[calc(100%-56px)] bg-gradient-to-r from-accent/40 to-border md:block" />
  )}

  <!-- Connector line (mobile) -->
  {!isLast && (
    <div class="step-line absolute top-[56px] left-1/2 h-8 w-px -translate-x-1/2 md:hidden" />
  )}

  <h3 class="mb-1 font-display text-base font-bold text-text">{title}</h3>
  <p class="max-w-[200px] text-sm leading-relaxed text-text-muted">{description}</p>
</div>
