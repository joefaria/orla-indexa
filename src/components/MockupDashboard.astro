---
import MockupStatusBadge from './MockupStatusBadge.astro';

const rows = [
  { param: 'Concentração máx.', investorVal: '10%', investeeVal: '8.2%', status: 'conforme' as const },
  { param: 'Classes permitidas', investorVal: 'RF, MM, Ações', investeeVal: 'MM', status: 'conforme' as const },
  { param: 'Rating mínimo', investorVal: 'AA', investeeVal: 'A+', status: 'atencao' as const },
  { param: 'Limite exterior', investorVal: '0%', investeeVal: '0%', status: 'conforme' as const },
  { param: 'Prazo médio', investorVal: '< 5 anos', investeeVal: '3.2 anos', status: 'conforme' as const },
  { param: 'Derivativos', investorVal: 'Hedge only', investeeVal: 'Hedge + Alavancagem', status: 'risco' as const },
];
---

<div class="reveal mt-12 rounded-xl border border-border bg-surface overflow-hidden">
  <!-- Dashboard header -->
  <div class="flex flex-col gap-3 border-b border-border bg-bg-alt px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="font-mono text-[10px] font-medium tracking-wider text-text-dim uppercase">Análise de Enquadramento</p>
      <p class="mt-1 text-sm text-text-muted">Comparação de conformidade entre investidor e investido</p>
    </div>
    <div class="flex items-center gap-3">
      <span class="rounded-full bg-signal-glow px-2.5 py-1 font-mono text-[10px] font-semibold text-signal">4 Conforme</span>
      <span class="rounded-full bg-warning-glow px-2.5 py-1 font-mono text-[10px] font-semibold text-warning">1 Atenção</span>
      <span class="rounded-full bg-risk-glow px-2.5 py-1 font-mono text-[10px] font-semibold text-risk">1 Risco</span>
    </div>
  </div>

  <!-- Column headers -->
  <div class="grid grid-cols-[1fr_1fr_1fr_auto] items-center border-b border-border bg-bg-alt/50 px-5 py-2.5 text-[10px]">
    <span class="font-mono font-medium tracking-wider text-text-dim uppercase">Parâmetro</span>
    <span class="font-mono font-medium tracking-wider text-accent-light uppercase">Investidor — Fundo ABC FIA</span>
    <span class="font-mono font-medium tracking-wider text-accent-light uppercase">Investido — Fundo XYZ FIM</span>
    <span class="font-mono font-medium tracking-wider text-text-dim uppercase">Status</span>
  </div>

  <!-- Data rows -->
  <div class="divide-y divide-border/30">
    {rows.map((row, i) => (
      <div
        class:list={[
          'mockup-row grid grid-cols-[1fr_1fr_1fr_auto] items-center px-5 py-3.5 transition-colors hover:bg-surface-hover',
          row.status === 'risco' && 'bg-risk-glow/30',
          row.status === 'atencao' && 'bg-warning-glow/30',
        ]}
        style={`animation-delay: ${0.6 + i * 0.12}s;`}
      >
        <span class="text-sm font-medium text-text">{row.param}</span>
        <span class="font-mono text-sm text-text-muted">{row.investorVal}</span>
        <span class="font-mono text-sm text-text-muted">{row.investeeVal}</span>
        <MockupStatusBadge status={row.status} />
      </div>
    ))}
  </div>

  <!-- Footer action bar -->
  <div class="flex items-center justify-between border-t border-border bg-bg-alt px-5 py-3">
    <span class="text-xs text-text-dim">Última atualização: há 2 min</span>
    <div class="flex items-center gap-3">
      <span class="cursor-default rounded-lg border border-border px-3 py-1.5 font-mono text-xs text-text-muted transition-colors hover:border-accent hover:text-accent">
        Exportar Parecer
      </span>
      <span class="cursor-default rounded-lg bg-accent px-3 py-1.5 font-mono text-xs font-semibold text-white">
        Aprovar Análise
      </span>
    </div>
  </div>
</div>
